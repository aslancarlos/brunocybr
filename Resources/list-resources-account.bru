meta {
  name: List resources (account)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/resources/{{account}}
  body: none
  auth: none
}

params:path {
  account: {{account}}
}

params:query {
  ~kind: variable
}

headers {
  Authorization: Token token="{{accessToken}}"
}

tests {
  test("status is 2xx", function() {
    expect(res.getStatus()).to.be.within(200, 299);
  });
}

docs {
  Lista recursos dentro de um account.
