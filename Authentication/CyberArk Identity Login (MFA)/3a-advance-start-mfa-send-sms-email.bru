meta {
  name: 3a. Advance - start MFA (send SMS/Email)
  type: http
  seq: 3
}

post {
  url: {{identityUrl}}/Security/AdvanceAuthentication
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-IDAP-NATIVE-CLIENT: true
}

body:json {
  {
    "SessionId": "{{idSessionId}}",
    "MechanismId": "{{idMechMfa}}",
    "Action": "StartOTP"
  }
}

docs {
  Dispara o envio do código MFA (SMS/e-mail). PULE se o MFA for app autenticador (TOTP) ou push.
}
