meta {
  name: Change password
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/authn/{{account}}/password
  body: text
  auth: basic
}

params:path {
  account: {{account}}
}

auth:basic {
  username: {{login}}
  password: {{password}}
}

body:text {
  {{newPassword}}
}

tests {
  test("status is 2xx", function() {
    expect(res.getStatus()).to.be.within(200, 299);
  });
}

docs {
  Altera a senha do usuário (Basic Auth com a senha atual; corpo = nova senha).
}
