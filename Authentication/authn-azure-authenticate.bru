meta {
  name: authn-azure authenticate
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/authn-azure/{{serviceId}}/{{account}}/{{workloadId}}/authenticate
  body: text
  auth: none
}

params:path {
  serviceId: {{serviceId}}
  account: {{account}}
  workloadId: {{workloadId}}
}

headers {
  Content-Type: application/x-www-form-urlencoded
  Accept-Encoding: base64
}

body:text {
  jwt={{azureAccessToken}}
}

script:post-response {
  const body = res.getBody();
  if (res.getStatus() === 200 && body) {
    // token base64 (Accept-Encoding: base64) — pronto para o header Authorization
    bru.setEnvVar("accessToken", typeof body === "string" ? body : JSON.stringify(body));
  }
}

tests {
  test("status is 2xx", function() {
    expect(res.getStatus()).to.be.within(200, 299);
  });
}

docs {
  Autentica um workload Azure usando o access token da Managed Identity (campo jwt).
}
